# Stripe (required for Unlock / checkout)
STRIPE_SECRET_KEY=sk_test_xxxx
# For production: add STRIPE_WEBHOOK_SECRET (whsec_xxx) and use live key on Netlify

# Optional: for redirect URLs and magic link
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: OpenAI for preview + full plan
OPENAI_API_KEY=sk-proj-xxxx

# Optional: Upstash Redis for plan store (or in-memory fallback)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: email with plan + magic link
RESEND_API_KEY=
SLEEP_EMAIL_FROM=Scoopy Log <onboarding@resend.dev>
